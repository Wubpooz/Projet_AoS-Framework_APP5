        "dest": { "block": "step8DowngradeRole", "port": "exec/in" }
      },
      "c-downgrade-list-members": {
        "src": { "block": "step8DowngradeRole", "port": "exec/out" },
        "dest": { "block": "step9ListMembersAfterDowngrade", "port": "exec/in" }
      },
      "c-list-members-remove": {
        "src": { "block": "step9ListMembersAfterDowngrade", "port": "exec/out" },
        "dest": { "block": "step10RemoveMember", "port": "exec/in" }
      },
      "c-remove-list-after": {
