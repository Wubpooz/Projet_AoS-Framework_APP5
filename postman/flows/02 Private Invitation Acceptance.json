          "data": "const body = vars;\nif (body.id) pm.collectionVariables.set('collectionId', body.id);",
          "language": "text/javascript",
          "allowAnyType": false
        },
        "ui": {
          "label": "5b. Extract Collection ID",
          "namedInputsExpanded": false
        }
      },
