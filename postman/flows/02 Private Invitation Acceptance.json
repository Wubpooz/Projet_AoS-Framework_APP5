        "config": {
          "inputs": [
            {
              "name": "vars",
              "ref": {
                "block": "step3LoginOwner",
                "port": "response/body"
              }
            }
          ],
          "data": "const body = vars;\nif (body.sessionToken) pm.collectionVariables.set('ownerToken', body.sessionToken);\nif (body.user && body.user.id) pm.collectionVariables.set('ownerUserId', body.user.id);",
          "language": "text/javascript",
          "allowAnyType": false
        },
        "ui": {
          "label": "3b. Extract Owner Token",
          "namedInputsExpanded": false
