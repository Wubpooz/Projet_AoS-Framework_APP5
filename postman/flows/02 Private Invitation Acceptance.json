{
  "version": 1,
  "name": "02 Private Invitation Acceptance",
  "description": "Flow scenario for a private collection invitation and acceptance journey in Postman Local View.",
  "flow": {
    "description": "Scenario steps:\n1. Register temporary owner and invitee users.\n2. Log both users in and capture session tokens.\n3. Create a PRIVATE collection as the owner.\n4. Invite the invitee as a COLLABORATOR.\n5. List pending invitations as the invitee.\n6. Accept the invitation.\n7. Verify the invitee can access the private collection.\n8. Verify the accepted member appears in the member list.\n9. Delete the collection for cleanup.\n\nRecommended collection requests: Auth/01-04 and Collections/01,09-12,10,16.",
    "nodes": {
      "inviteFlowStart": {
        "type": "ev/endpoint@3",
        "pos": {
          "x": 0,
          "y": 0
        },
        "config": {
          "inputs": [],
          "data": "",
          "language": "json",
          "allowAnyType": false
        },
        "ui": {
          "data": {
            "triggerType": "ev/endpoint@3"
          },
          "namedInputsExpanded": true
        }
      },
      "step1RegisterOwner": {
        "type": "exec/request@1",
        "pos": {
          "x": 220,
          "y": 0
        },
        "config": {
          "inputs": [
            {
              "name": "url",
              "value": "{{baseUrl}}/api/auth/register"
            },
            {
              "name": "method",
              "value": "POST"
            },
            {
              "name": "header.Content-Type",
              "value": "application/json"
            },
            {
              "name": "body",
              "value": "{\"email\":\"{{ownerEmail}}\",\"password\":\"{{ownerPassword}}\",\"name\":\"Owner User\"}"
            }
          ],
          "data": "",
          "language": "json",
          "allowAnyType": false
        },
        "ui": {
          "label": "1. Register Owner",
          "namedInputsExpanded": false
        }
      },
      "step2RegisterInvitee": {
        "type": "exec/request@1",
        "pos": {
          "x": 220,
          "y": 160
        },
        "config": {
          "inputs": [
            {
              "name": "url",
              "value": "{{baseUrl}}/api/auth/register"
            },
            {
              "name": "method",
              "value": "POST"
            },
            {
              "name": "header.Content-Type",
              "value": "application/json"
            },
            {
              "name": "body",
              "value": "{\"email\":\"{{inviteeEmail}}\",\"password\":\"{{inviteePassword}}\",\"name\":\"Invitee User\"}"
            }
          ],
          "data": "",
          "language": "json",
          "allowAnyType": false
        },
        "ui": {
          "label": "2. Register Invitee",
          "namedInputsExpanded": false
        }
      },
      "step2bExtractInviteeId": {
        "type": "sandbox/evaluate@1",
        "pos": {
          "x": 220,
          "y": 300
        },
        "config": {
          "inputs": [
            {
              "name": "vars",
              "ref": {
                "block": "step2RegisterInvitee",
                "port": "response/body"
              }
            }
          ],
          "data": "const body = vars;\nif (body.user && body.user.id) pm.collectionVariables.set('inviteeUserId', body.user.id);",
          "language": "text/javascript",
          "allowAnyType": false
        },
        "ui": {
          "label": "2b. Extract Invitee ID",
          "namedInputsExpanded": false
        }
      },
